# LLM backend: "openai" (default) or "local" (Ollama)
LLM_BACKEND=openai
OPENAI_API_KEY=sk-...

# Vision backend: "openai" (GPT-4o) or "local" (Qwen2-VL | moondream via Ollama)
VISION_BACKEND=openai

# Embedding backend: "openai" or "local" (BAAI/bge-m3)
EMBEDDING_BACKEND=openai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Databricks (optional)
DATABRICKS_HOST=...
DATABRICKS_HTTP_PATH=...
DATABRICKS_TOKEN=...